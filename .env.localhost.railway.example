APP_ENV=local

# Localhost / XAMPP connecting to Railway PostgreSQL.
# Use the Railway PUBLIC endpoint when the app runs on your laptop.
DATABASE_URL=postgresql://postgres:SZsBokcajFtrkUbGDXjhIRCnAvkJQcxW@<railway-public-host>:<railway-public-port>/railway

DATABASE_PUBLIC_URL=postgresql://${PGUSER}:${POSTGRES_PASSWORD}@${RAILWAY_TCP_PROXY_DOMAIN}:${RAILWAY_TCP_PROXY_PORT}/${PGDATABASE}
DATABASE_URL_PRIVATE=postgresql://${PGUSER}:${POSTGRES_PASSWORD}@${RAILWAY_PRIVATE_DOMAIN}:5432/${PGDATABASE}
PGDATA=/var/lib/postgresql/data/pgdata
PGDATABASE=railway
PGHOST=${RAILWAY_PRIVATE_DOMAIN}
PGPASSWORD=SZsBokcajFtrkUbGDXjhIRCnAvkJQcxW
PGPORT=5432
PGUSER=postgres
POSTGRES_DB=railway
POSTGRES_PASSWORD=SZsBokcajFtrkUbGDXjhIRCnAvkJQcxW
POSTGRES_USER=postgres
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=60
SSL_CERT_DAYS=820
