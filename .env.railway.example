APP_ENV=production

# Use the Railway PostgreSQL values you received in the Railway dashboard.
# Keep real secrets in Railway variables or a local .env file, not in Git.
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/railway
DATABASE_PUBLIC_URL=postgresql://postgres:<password>@<public-host>:<public-port>/railway
PGDATA=/var/lib/postgresql/data/pgdata
PGDATABASE=railway
PGHOST=<railway-private-domain>
PGPASSWORD=<railway-password>
PGPORT=5432
PGUSER=postgres
POSTGRES_DB=railway
POSTGRES_PASSWORD=<railway-password>
POSTGRES_USER=postgres
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=60
SSL_CERT_DAYS=820
